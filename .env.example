# ===== Auth =====
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ===== Database =====
# Local SQLite (default) or a Supabase/Postgres URL:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/estate
DATABASE_URL=sqlite:///./estate.db

# ===== Redis / Celery =====
REDIS_URL=redis://localhost:6379/0

# ===== AI (OpenRouter, OpenAI-compatible) =====
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=
AI_MODEL=google/gemma-4-31b-it:free
# AI_VISION_MODEL defaults to AI_MODEL
AI_RECOMMEND_MODEL=deepseek/deepseek-r1:free
AI_MAX_TOKENS=1024
AI_APP_URL=http://localhost:3000
AI_APP_TITLE=AI Real Estate Marketplace

# ===== Mapbox =====
MAPBOX_TOKEN=

# ===== Email (Gmail SMTP via App Password) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=AI Real Estate
SMTP_USE_TLS=true
EMAIL_CODE_TTL_MIN=10
EMAIL_CODE_MAX_ATTEMPTS=5
REQUIRE_EMAIL_VERIFICATION=false

# ===== Payments (built-in MockPay gateway, no external keys) =====
PAYMENTS_BASE_URL=http://localhost:8000
PAYMENT_CURRENCY=usd
PAYMENT_SESSION_TTL_MIN=30

# ===== Moderation =====
COMPLAINT_THRESHOLD=3

# ===== Rate limiting (AI endpoints, per user) =====
AI_RATE_LIMIT=20
AI_RATE_WINDOW_SEC=60
