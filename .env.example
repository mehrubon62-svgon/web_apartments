# ===== Auth =====
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ===== Database =====
# Local SQLite (default) or a Supabase/Postgres URL:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/estate
DATABASE_URL=sqlite:///./estate.db

# ===== Redis / Celery =====
REDIS_URL=redis://localhost:6379/0

# ===== AI (OpenRouter, OpenAI-compatible) =====
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=
AI_MODEL=google/gemma-4-31b-it:free
# AI_VISION_MODEL defaults to AI_MODEL
AI_MAX_TOKENS=1024
AI_APP_URL=http://localhost:3000
AI_APP_TITLE=AI Real Estate Marketplace

# ===== Mapbox =====
MAPBOX_TOKEN=

# ===== Stripe =====
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:3000/bookings?paid=1
STRIPE_CANCEL_URL=http://localhost:3000/bookings?canceled=1

# ===== Moderation =====
COMPLAINT_THRESHOLD=3
